{
  "type": "excalidraw",
  "version": 2,
  "source": "https://excalidraw.com",
  "elements": [
    {
      "type": "rectangle",
      "version": 1,
      "x": 50,
      "y": 50,
      "width": 250,
      "height": 80,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "frontend-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0e8ff",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 120,
      "y": 70,
      "width": 120,
      "height": 25,
      "id": "frontend-text",
      "text": "SvelteKit Frontend\n(shadcn-svelte UI)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "arrow",
      "version": 1,
      "x": 300,
      "y": 90,
      "width": 80,
      "height": 0,
      "id": "arrow-fe-to-be",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "points": [
        [0, 0],
        [80, 0]
      ],
      "startBinding": { "elementId": "frontend-box", "focus": 0 },
      "endBinding": { "elementId": "tauri-box", "focus": 0 }
    },
    {
      "type": "rectangle",
      "version": 1,
      "x": 380,
      "y": 50,
      "width": 200,
      "height": 80,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "tauri-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffe0b0",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 420,
      "y": 70,
      "width": 120,
      "height": 25,
      "id": "tauri-text",
      "text": "Tauri v2 Bridge\n(IPC / invoke)",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "arrow",
      "version": 1,
      "x": 580,
      "y": 90,
      "width": 80,
      "height": 0,
      "id": "arrow-tauri-to-rust",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "points": [
        [0, 0],
        [80, 0]
      ],
      "startBinding": { "elementId": "tauri-box", "focus": 0 },
      "endBinding": { "elementId": "rust-box", "focus": 0 }
    },
    {
      "type": "rectangle",
      "version": 1,
      "x": 660,
      "y": 30,
      "width": 300,
      "height": 120,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "rust-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#c8f0c8",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 710,
      "y": 55,
      "width": 200,
      "height": 70,
      "id": "rust-text",
      "text": "Rust Backend\n- SSH Config (read/write/parse)\n- Git Config (read/write/parse)\n- Connection Testing",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "arrow",
      "version": 1,
      "x": 660,
      "y": 150,
      "width": -100,
      "height": 60,
      "id": "arrow-rust-to-ssh",
      "strokeColor": "#2d8a2d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "points": [
        [0, 0],
        [-100, 60]
      ]
    },
    {
      "type": "rectangle",
      "version": 1,
      "x": 480,
      "y": 210,
      "width": 180,
      "height": 60,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "ssh-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f0c8c8",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 500,
      "y": 225,
      "width": 140,
      "height": 25,
      "id": "ssh-text",
      "text": "~/.ssh/config\nSSH Key Files",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "arrow",
      "version": 1,
      "x": 760,
      "y": 150,
      "width": 100,
      "height": 60,
      "id": "arrow-rust-to-git",
      "strokeColor": "#2d8a2d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "points": [
        [0, 0],
        [100, 60]
      ]
    },
    {
      "type": "rectangle",
      "version": 1,
      "x": 780,
      "y": 210,
      "width": 180,
      "height": 60,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "git-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#c8c8f0",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 800,
      "y": 225,
      "width": 140,
      "height": 25,
      "id": "git-text",
      "text": "~/.gitconfig\n~/.ssh/config (Git hosts)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "rectangle",
      "version": 1,
      "x": 50,
      "y": 200,
      "width": 300,
      "height": 80,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "id": "pages-box",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff0d0",
      "roundness": { "type": 3 }
    },
    {
      "type": "text",
      "version": 1,
      "x": 70,
      "y": 215,
      "width": 260,
      "height": 50,
      "id": "pages-text",
      "text": "Pages:\n- / (Home)\n- /ssh (SSH Configuration)\n- /git (Git Configuration)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100
    },
    {
      "type": "line",
      "version": 1,
      "x": 50,
      "y": 130,
      "width": 0,
      "height": 70,
      "id": "line-frontend-to-pages",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 1,
      "opacity": 100,
      "points": [
        [0, 0],
        [0, 70]
      ]
    },
    {
      "type": "text",
      "version": 1,
      "x": 100,
      "y": 320,
      "width": 800,
      "height": 80,
      "id": "desc-text",
      "text": "Architecture: Workstation App\nFrontend (SvelteKit) → Tauri v2 IPC → Rust Backend → SSH/Git Configs\nshadcn-svelte UI components | Tailwind v4 | ChatGPT-style collapsible sidebar",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "center",
      "strokeColor": "#666",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 80
    }
  ],
  "appState": {
    "gridSize": null,
    "viewBackgroundColor": "#ffffff"
  }
}
